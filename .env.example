# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# Optional: explicit origins (comma-separated). If unset, https:// is added for each ALLOWED_HOST.
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Set True when running locally over HTTP with DEBUG=False (e.g. runserver)
ALLOW_INSECURE_COOKIES=True

# ConCat (CONCAT_TOKEN_ENDPOINT defaults to {CONCAT_API_BASE}/api/oauth/token)
CONCAT_ENABLED=False
CONCAT_API_BASE=https://reg.example.org
CONCAT_CLIENT_ID=0
CONCAT_CLIENT_SECRET=123456789abcdef
CONCAT_REDIRECT_URI=https://yourdomain.com/

# ConCat Integration   
CONCAT_EVENTS_ROLE=staff,events
CONCAT_SKIP_RSVP_ROLES=admin,events
CONCAT_RSVP_REQUIRED_ROLES=attendee
CONCAT_REQUIRE_PAID_REGISTRATION=True
CONCAT_RSVP_PRODUCT_IDS=1,2,3

# Eventzilla Integration
EVENTZILLA_ENABLED=False
EVENTZILLA_API_BASE=https://www.eventzillaapi.net/api/v2
EVENTZILLA_API_KEY=0
EVENTZILLA_EVENT_ID=1234567890
EVENTZILLA_REQUIRE_PAID_REGISTRATION=True
# Optional comma-separated ticket types (empty = any ticket)
EVENTZILLA_ALLOWED_TICKET_TYPES=Attendee
